{
  "name": "@ark/luban",
  "version": "1.0.3",
  "description": "HarmonyOS ArkTS 图片压缩库，参考 Luban 压缩策略，支持批量压缩、URI 预处理、EXIF 方向处理和 JPEG 质量调节",
  "main": "Index.ets",
  "author": "ark",
  "license": "Apache-2.0",
  "repository": "https://github.com/kumaleap/ArkLuban.git",
  "keywords": [
    "图片",
    "压缩",
    "压缩图片",
    "图片压缩",
    "image",
    "compression",
    "luban"
  ],
  "bugs": {
    "url": "https://github.com/kumaleap/ArkLuban/issues"
  },
  "homepage": "https://github.com/kumaleap/ArkLuban#readme",
  "engines": {
    "harmonyos": ">=4.0.0"
  },
  "compileSdkVersion": 12,
  "compatibleSdkVersion": 12,
  "dependencies": {}
}
